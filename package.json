{
  "name": "stillmark-workbench",
  "version": "0.2.0",
  "description": "A quiet collection of focused tools for SiYuan Note.",
  "main": "index.js",
  "scripts": {
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "dev": "webpack --config webpack.config.js --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "check": "run-s format:check lint build"
  },
  "keywords": [
    "siyuan",
    "stillmark",
    "workbench",
    "block-style"
  ],
  "author": "houm01",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "dprint": "latest",
    "esbuild-loader": "^4.4.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.100.0",
    "sass-loader": "^17.0.0",
    "siyuan": "1.2.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "zip-webpack-plugin": "^4.0.3"
  },
  "dependencies": {
    "@lillallol/outline-pdf": "4.0.0",
    "pdf-lib": "1.17.1"
  }
